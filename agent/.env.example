# RemoteConnect server endpoints
# Local dev (defaults):
SERVER_HTTP_URL=http://127.0.0.1:8765
SERVER_WS_URL=ws://127.0.0.1:8765
# Production (uncomment when installing on a real machine):
# SERVER_HTTP_URL=https://remoteconnect.ikieguy.online
# SERVER_WS_URL=wss://remoteconnect.ikieguy.online

# Optional: override the machine name (defaults to system hostname)
MACHINE_NAME=

# Heartbeat interval in seconds (PRD: 30)
HEARTBEAT_INTERVAL_S=30

# Daily.co publisher command run on start_session. Empty = log-only.
# Available substitutions via env: $DAILY_ROOM_URL $DAILY_MEETING_TOKEN $DAILY_SESSION_ID
#
# Recommended (uses the bundled Daily SDK publisher — see agent/publisher_daily.py):
# DAILY_PUBLISHER_CMD=/path/to/agent/venv/bin/python -m agent.publisher_daily
#
# Optional tuning for the bundled publisher:
#   PUBLISHER_FPS=15  PUBLISHER_WIDTH=1280  PUBLISHER_HEIGHT=720
#
# Alternative (headless chromium — works on macOS/Windows, fragile on Linux):
# DAILY_PUBLISHER_CMD=chromium --headless=new --use-fake-ui-for-media-stream "$DAILY_ROOM_URL?t=$DAILY_MEETING_TOKEN"
DAILY_PUBLISHER_CMD=

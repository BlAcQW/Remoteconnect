<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!--
  Windows application manifest for the agent .exe.

  Why this matters for Defender heuristics:
  - A binary with a real manifest reads as a properly-built Windows app rather
    than a "stripped" malware-style binary. Microsoft's ML model gives manifests
    significant positive weight.
  - requestedExecutionLevel=asInvoker explicitly tells Windows we don't want
    elevation. Anything claiming admin without UAC is a red flag — being
    explicit about NOT asking for it is a green flag.
  - PerMonitorV2 DPI awareness fixes blurry text / mis-scaled tk dialogs on
    high-DPI laptops, which is a common customer complaint independent of
    Defender.
-->
<assembly xmlns="urn:schemas-microsoft-com:asm.v1" manifestVersion="1.0" xmlns:asmv3="urn:schemas-microsoft-com:asm.v3">
  <assemblyIdentity
      type="win32"
      name="RemoteConnect.Agent"
      version="1.0.0.0"
      processorArchitecture="*"/>
  <description>RemoteConnect Remote Support Agent</description>

  <!-- Don't elevate. UAC stays out of the customer's way. -->
  <trustInfo xmlns="urn:schemas-microsoft-com:asm.v3">
    <security>
      <requestedPrivileges>
        <requestedExecutionLevel level="asInvoker" uiAccess="false"/>
      </requestedPrivileges>
    </security>
  </trustInfo>

  <!-- Per-monitor DPI awareness so the install window + consent dialog
       render crisply on HiDPI laptops, including monitor-DPI changes. -->
  <asmv3:application>
    <asmv3:windowsSettings>
      <dpiAware xmlns="http://schemas.microsoft.com/SMI/2005/WindowsSettings">true/PM</dpiAware>
      <dpiAwareness xmlns="http://schemas.microsoft.com/SMI/2016/WindowsSettings">PerMonitorV2,PerMonitor</dpiAwareness>
      <longPathAware xmlns="http://schemas.microsoft.com/SMI/2016/WindowsSettings">true</longPathAware>
    </asmv3:windowsSettings>
  </asmv3:application>

  <!-- Compatibility: tell Windows we know about 10 and 11. -->
  <compatibility xmlns="urn:schemas-microsoft-com:compatibility.v1">
    <application>
      <!-- Windows 10 / 11 -->
      <supportedOS Id="{8e0f7a12-bfb3-4fe8-b9a5-48fd50a15a9a}"/>
      <!-- Windows 8.1 -->
      <supportedOS Id="{1f676c76-80e1-4239-95bb-83d0f6d0da78}"/>
      <!-- Windows 8 -->
      <supportedOS Id="{4a2f28e3-53b9-4441-ba9c-d69d4a4a6e38}"/>
      <!-- Windows 7 -->
      <supportedOS Id="{35138b9a-5d96-4fbd-8e2d-a2440225f93a}"/>
    </application>
  </compatibility>
</assembly>

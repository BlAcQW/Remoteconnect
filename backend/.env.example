# Database (defaults to local SQLite if unset)
DATABASE_URL=sqlite+aiosqlite:///./remoteconnect.db

# JWT — required, 32+ chars. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars

# Daily.co — leave blank in dev to use the mocked room URL
DAILY_API_KEY=

# CORS allowlist for the FastAPI app (comma-separated origins). The browser
# normally talks to the Next.js proxy (`/api/*`), not FastAPI directly, so
# this only matters for direct API consumers.
CORS_ORIGINS=http://localhost:3000

# Environment selector: "development" (default) or "production".
# In production:
#   - /docs, /redoc, and /openapi.json are hidden
ENVIRONMENT=development

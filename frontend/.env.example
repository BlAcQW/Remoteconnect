# FastAPI backend URL — server-side only (NOT exposed to the browser).
# All API traffic from the browser is proxied through Next.js Route Handlers
# under /api/* so the JWT lives only in an httpOnly cookie.
BACKEND_URL=http://127.0.0.1:8765

# Cookie attributes
JWT_COOKIE_NAME=rc_jwt
# 24h to match the backend's ACCESS_TOKEN_EXPIRE_MINUTES
JWT_COOKIE_MAX_AGE_S=86400
